## 3. Logika Backend (The Core Sync)

### Helper: [backend/utils/cashflowHelper.js](file:///Users/macbook/projects/kue_lapis/backend/utils/cashflowHelper.js)
Gunakan logika ini untuk sinkronisasi otomatis.

```javascript
const Cashflow = require('../models/Cashflow');
const BalanceTransaction = require('../models/BalanceTransaction');

const syncProductWithCashflow = async (product, userId) => {
    if (!product.harga || product.harga <= 0) return;
    if (product.paymentStatus !== 'paid' && product.status !== 'completed') return;

    try {
        let cashflowEntry = await Cashflow.findOne({ productId: product._id });
        const cashflowData = {
            type: 'expense',
            category: 'Pembayaran Produk',
            amount: product.harga,
            description: `Otomatis: Pembayaran ${product.nama} (${product.noOrder})`,
            date: product.updatedAt || new Date(),
            productId: product._id,
            isDebt: product.paymentStatus !== 'paid',
            lastModifiedBy: userId,
            account: 'Rekening A'
        };

        if (cashflowEntry) {
            Object.assign(cashflowEntry, cashflowData);
            await cashflowEntry.save();
        } else {
            cashflowData.createdBy = userId;
            cashflowEntry = new Cashflow(cashflowData);
            await cashflowEntry.save();
        }

        // Ledger Sync (Only if Paid)
        if (!cashflowData.isDebt) {
            let balanceEntry = await BalanceTransaction.findOne({ reference: product._id.toString() });
            const balanceData = {
                type: 'expense',
                amount: product.harga,
                reference: product._id.toString(),
                lastModifiedBy: userId
            };
            if (balanceEntry) {
                Object.assign(balanceEntry, balanceData);
                await balanceEntry.save();
            } else {
                balanceData.createdBy = userId;
                await new BalanceTransaction(balanceData).save();
            }
        } else {
            await BalanceTransaction.findOneAndDelete({ reference: product._id.toString() });
        }
    } catch (error) {
        console.error('Sync Error:', error);
    }
};
```

